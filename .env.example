# UID/GID of the host user — used so files created inside the container
# are owned by you (not root). Run: id -u && id -g to get these values.
UID=1000
GID=1000

# Log verbosity for the MCP server: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Test credentials (used ONLY for e2e real-API tests) ──────────────────────
# These are NOT used by the MCP server itself at runtime.
# The server receives domain/api_key from MCP tool call parameters.
TEST_DOMAIN=devtr6
TEST_API_KEY=
