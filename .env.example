# UID/GID of the host user — used so files created inside the container
# are owned by you (not root). Run: id -u && id -g to get these values.
UID=1000
GID=1000

# Log verbosity for the MCP server: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Local host-based MCP (Cursor -> http://localhost:8000/mcp) ────────────────
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PATH=/mcp
PORT=8000
WEB_SESSION_SECRET=
# Generate with: python -c "from secret_manager import generate_storage_encryption_key; print(generate_storage_encryption_key())"
STORAGE_ENCRYPTION_KEY=

# ── Test credentials (used ONLY for e2e real-API tests) ──────────────────────
# Runtime credentials Vetmanager are not stored here.
# MCP clients use Authorization: Bearer <service_token>; clinic domain/api_key
# live inside the service account storage layer.
TEST_DOMAIN=
TEST_API_KEY=
TEST_USER_TOKEN=
TEST_USER_TOKEN_BASE_URL=
TEST_USER_LOGIN=
TEST_USER_PASSWORD=
